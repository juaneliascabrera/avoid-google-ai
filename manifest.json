{
  "manifest_version": 3,
  "name": "Google Sin IA",
  "version": "1.2",
  "description": "Fuerza las búsquedas de Google a mostrar solo resultados web clásicos, sin IA.",
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "*://*.google.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
